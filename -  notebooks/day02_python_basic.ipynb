# 能源AI项目1：电力负荷预测
# ==========================

# 1. 导入必备库（数据分析三剑客）
import pandas as pd    # 注释：处理表格数据（Excel/CSV）
import numpy as np     # 注释：数值计算
import matplotlib.pyplot as plt  # 注释：画图

# 2. 打印测试，看是否导入成功
print("第2天学习开始！")
print("库导入成功 ✅")

# 3. 创建一个简单模拟负荷数据（后面会用真实电网数据）
# 注释：模拟48小时的负荷数据，单位MW
hours = np.arange(1, 49)  # 1~48小时
load = 200 + np.random.randn(48) * 10  # 模拟负荷

# 4. 用DataFrame保存成表格
df = pd.DataFrame({
    'hour': hours,
    'load_mw': load
})

# 5. 展示前5行数据
print("\n负荷数据预览：")
print(df.head())

# 6. 简单画图
plt.figure(figsize=(12, 4))
plt.plot(df['hour'], df['load_mw'], marker='o', label='模拟负荷')
plt.title('48小时模拟电力负荷')
plt.xlabel('小时')
plt.ylabel('负荷(MW)')
plt.legend()
plt.show()

print("\n第2天代码运行完成！明天开始正式处理真实数据。")
